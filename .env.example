# Postgres connectiestring (Neon of Vercel Postgres)
DATABASE_URL=

# Auth.js secret, genereer met: npx auth secret
AUTH_SECRET=

# Resend voor magic link e-mails
RESEND_API_KEY=
# onboarding@resend.dev werkt zonder eigen domein (Resend sandbox-adres),
# vervang door een geverifieerd domein-adres voor productie
AUTH_EMAIL_FROM=onboarding@resend.dev

# Alleen deze adressen mogen inloggen
ALLOWED_EMAILS=jij@example.com,partner@example.com
